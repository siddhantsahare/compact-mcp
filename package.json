{
  "name": "compact-for-copilot",
  "displayName": "Compact",
  "description": "Smart context optimizer for React. Fit massive components into Copilot with zero token bloat.",
  "publisher": "compact-labs",
  "icon": "assets/icon.png",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:compact-for-copilot.compact"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "compact": "./dist/cli.js"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "compact-for-copilot.compact",
        "name": "compact",
        "description": "Autonomous React assistant — safely optimizes workspace files and streams precise fixes.",
        "isSticky": true
      }
    ],
    "languageModelTools": [
      {
        "name": "compact_search_workspace",
        "tags": ["compact"],
        "description": "Search the workspace for React component and hook files matching a keyword. Returns a list of matching file paths.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "keyword": {
              "type": "string",
              "description": "A filename keyword or glob fragment to search for (e.g. 'Button', 'useAuth', 'Header')."
            }
          },
          "required": ["keyword"]
        }
      },
      {
        "name": "compact_read_and_compress",
        "tags": ["compact"],
        "description": "Read a React/TypeScript file from the workspace, intelligently compress it for minimal token usage, and return the optimised source. Use this to understand a file's structure and logic efficiently.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filePath": {
              "type": "string",
              "description": "Workspace-relative path to the file to read and compress (e.g. 'src/components/Button.tsx')."
            }
          },
          "required": ["filePath"]
        }
      }
    ],
    "commands": [
      {
        "command": "compact.compressFile",
        "title": "Compact: Compress Active File",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "compact.compressSelection",
        "title": "Compact: Compress Selection",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "compact.copyCompressed",
        "title": "Compact: Copy Compressed to Clipboard",
        "icon": "$(clippy)"
      }
    ],
    "keybindings": [
      {
        "command": "compact.copyCompressed",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c",
        "when": "editorTextFocus && resourceExtname =~ /\\.[jt]sx?$/"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "compact.copyCompressed",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "9_cutcopypaste@99"
        },
        {
          "command": "compact.compressFile",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "9_cutcopypaste@100"
        }
      ],
      "editor/title": [
        {
          "command": "compact.copyCompressed",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run build:tsc && npm run bundle:extension",
    "build:tsc": "tsc",
    "bundle:extension": "esbuild src/extension.ts --bundle --minify --platform=node --target=node18 --format=cjs --external:vscode --outfile=dist/extension.js",
    "watch": "tsc --watch",
    "watch:bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --external:vscode --outfile=dist/extension.js --watch",
    "vscode:prepublish": "npm run build",
    "package:vsix": "npx @vscode/vsce package --allow-missing-repository --skip-license",
    "inspect:vsix": "npx @vscode/vsce ls --tree",
    "benchmark": "npm run build && node dist/benchmark.js",
    "evals": "npm run build && node dist/run_evals.js",
    "evals:dry": "npm run build && node dist/run_evals.js --dry-run",
    "lint": "eslint src/",
    "pretest": "npm run build && npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "@babel/generator": "^7.22.5",
    "@babel/parser": "^7.22.5",
    "@babel/traverse": "^7.22.5",
    "@babel/types": "^7.22.5"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3"
  }
}
