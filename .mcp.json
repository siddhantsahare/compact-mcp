{
  "mcpServers": {
    "compact": {
      "command": "/mnt/c/Program Files/nodejs/node.exe",
      "args": ["dist/mcp/index.js"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}

