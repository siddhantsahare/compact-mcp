    "@babel/parser": "^7.22.5",
    "@babel/traverse": "^7.22.5",
    "@babel/types": "^7.22.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "glob": "^11.0.0",
    "gpt-tokenizer": "^3.4.0"
  },
  "repository": {
